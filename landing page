<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Vault — Secured</title>
  <meta name="description" content="Vault — the unified vessel management platform built by crew, for crew." />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500&display=swap" rel="stylesheet" />
  <style>

    /* ── TOKENS ──────────────────────────────────────────────── */
    :root {
      --forest:       #1B2B1A;
      --deep-sage:    #2E4A2D;
      --off-white:    #FAFAF8;
      --cream:        #F5F2EB;
      --warm-linen:   #EBE6DB;
      --sand:         #D8D3C5;
      --text-primary: #1B2B1A;
      --text-sec:     #5A6B59;
      --text-tert:    #8FA08E;
      --sky-blue:     #87BCED;
      --mist:         #B8CBE8;
      --sky-deep:     #5A9ED4;
      --sky-pale:     #D6E8F7;
      --toggle-blue:  #4A8CF7;
      --border:       #D8D3C5;
      --border-light: #EBE6DB;
    }

    /* ── RESET ───────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }

    body {
      background: var(--off-white);
      color: var(--text-primary);
      font-family: 'DM Sans', sans-serif;
      font-size: 15px;
      line-height: 1.65;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ── NAV ─────────────────────────────────────────────────── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      height: 56px;
      background: rgba(245, 242, 235, 0.96);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border-light);
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .nav-inner {
      width: 100%;
      max-width: 1440px;
      padding: 0 52px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .nav-logo {
      display: flex;
      align-items: center;
      gap: 11px;
      text-decoration: none;
    }
    .nav-wordmark {
      font-family: 'DM Serif Display', serif;
      font-size: 18px;
      letter-spacing: 0.12em;
      color: var(--forest);
    }
    .nav-domain {
      font-size: 11px;
      font-weight: 400;
      color: var(--text-tert);
      letter-spacing: 0.04em;
    }

    /* ── MAIN ────────────────────────────────────────────────── */
    main {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 120px 52px 80px;
      max-width: 1440px;
      width: 100%;
      margin: 0 auto;
    }

    /* ── HERO CARD ───────────────────────────────────────────── */
    .hero {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      max-width: 560px;
      width: 100%;
    }

    /* Mark */
    .hero-mark {
      width: 52px;
      height: 52px;
      margin-bottom: 32px;
      opacity: 0.92;
    }

    /* Wordmark */
    .hero-wordmark {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(64px, 10vw, 108px);
      letter-spacing: 0.1em;
      color: var(--forest);
      line-height: 1;
      margin-bottom: 20px;
    }

    /* Rule */
    .hero-rule {
      width: 40px;
      height: 1.5px;
      background: var(--sand);
      border-radius: 2px;
      margin-bottom: 20px;
    }

    /* Slogan */
    .hero-slogan {
      font-family: 'DM Serif Display', serif;
      font-style: italic;
      font-size: clamp(18px, 2.5vw, 22px);
      color: var(--text-sec);
      letter-spacing: 0.04em;
      margin-bottom: 18px;
    }

    /* Description */
    .hero-desc {
      font-size: 14px;
      font-weight: 300;
      color: var(--text-tert);
      line-height: 1.75;
      letter-spacing: 0.01em;
      max-width: 400px;
      margin-bottom: 44px;
    }

    /* CTA group */
    .hero-ctas {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      justify-content: center;
    }

    /* Buttons */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 9px;
      padding: 12px 26px;
      border-radius: 50px;
      font-family: 'DM Sans', sans-serif;
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 0.04em;
      cursor: pointer;
      text-decoration: none;
      border: none;
      transition: background 0.18s ease, color 0.18s ease, box-shadow 0.18s ease, opacity 0.18s ease;
    }
    .btn-primary {
      background: var(--toggle-blue);
      color: #ffffff;
    }
    .btn-primary:hover {
      background: #3a7be6;
      box-shadow: 0 4px 18px rgba(74, 140, 247, 0.28);
    }
    .btn-outline {
      background: transparent;
      color: var(--text-primary);
      border: 1.5px solid var(--sand);
    }
    .btn-outline:hover {
      border-color: var(--toggle-blue);
      color: var(--toggle-blue);
      background: var(--sky-pale);
    }

    /* Button icon */
    .btn-icon {
      flex-shrink: 0;
      display: flex;
      align-items: center;
    }

    /* ── DIVIDER ─────────────────────────────────────────────── */
    .section-divider {
      width: 100%;
      max-width: 1440px;
      margin: 0 auto;
      padding: 0 52px;
    }
    .section-divider hr {
      border: none;
      border-top: 1px solid var(--border-light);
    }

    /* ── FOOTER ──────────────────────────────────────────────── */
    footer {
      background: var(--cream);
      border-top: 1px solid var(--border-light);
      padding: 32px 52px;
    }
    .footer-inner {
      max-width: 1440px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      flex-wrap: wrap;
    }
    .footer-left {
      display: flex;
      align-items: center;
      gap: 11px;
    }
    .footer-wordmark {
      font-family: 'DM Serif Display', serif;
      font-size: 16px;
      letter-spacing: 0.12em;
      color: var(--forest);
    }
    .footer-right {
      font-size: 11px;
      color: var(--text-tert);
      letter-spacing: 0.04em;
      text-align: right;
      line-height: 1.7;
    }

    /* ── RESPONSIVE ──────────────────────────────────────────── */
    @media (max-width: 768px) {
      .nav-inner { padding: 0 24px; }
      .nav-domain { display: none; }
      main { padding: 100px 24px 60px; }
      footer { padding: 28px 24px; }
      .footer-right { text-align: left; }
    }

    @media (max-width: 480px) {
      .hero-ctas { flex-direction: column; align-items: center; }
      .btn { width: 100%; justify-content: center; }
      .hero-desc { font-size: 13px; }
    }

  </style>
</head>
<body>

  <!-- NAV -->
  <nav>
    <div class="nav-inner">
      <a class="nav-logo" href="/">
        <!-- VAULT mark -->
        <svg width="21" height="22" viewBox="0 0 100 104" fill="none" xmlns="http://www.w3.org/2000/svg">
          <defs><mask id="vmNL"><rect width="100" height="104" fill="black"/><path d="M8,8 L92,8 L50,96 Z" fill="white"/><rect x="8" y="8" width="84" height="9" fill="black"/><rect x="46" y="8" width="8" height="88" fill="black"/></mask></defs>
          <rect width="100" height="104" fill="#1B2B1A" mask="url(#vmNL)"/>
        </svg>
        <span class="nav-wordmark">VAULT</span>
      </a>
      <span class="nav-domain">veslvault.com</span>
    </div>
  </nav>

  <!-- MAIN HERO -->
  <main>
    <div class="hero">

      <!-- Mark — real Vault T-mark -->
      <svg class="hero-mark" viewBox="0 0 100 104" fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <mask id="vmH">
            <rect width="100" height="104" fill="black"/>
            <path d="M8,8 L92,8 L50,96 Z" fill="white"/>
            <rect x="8" y="8" width="84" height="9" fill="black"/>
            <rect x="46" y="8" width="8" height="88" fill="black"/>
          </mask>
        </defs>
        <rect width="100" height="104" fill="#1B2B1A" mask="url(#vmH)"/>
      </svg>

      <!-- Wordmark -->
      <h1 class="hero-wordmark">VAULT</h1>

      <!-- Rule -->
      <div class="hero-rule"></div>

      <!-- Slogan -->
      <p class="hero-slogan">Secured</p>

      <!-- Description -->
      <p class="hero-desc">
        The unified vessel management platform built by crew, for crew.
      </p>

      <!-- CTAs -->
      <div class="hero-ctas">

        <!-- Instagram -->
        <a class="btn btn-primary" href="https://instagram.com/veslvault" target="_blank" rel="noopener noreferrer">
          <span class="btn-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="2" y="2" width="20" height="20" rx="6" stroke="white" stroke-width="1.6"/>
              <circle cx="12" cy="12" r="4.5" stroke="white" stroke-width="1.6"/>
              <circle cx="17.5" cy="6.5" r="1" fill="white"/>
            </svg>
          </span>
          Follow on Instagram
        </a>

        <!-- Email -->
        <a class="btn btn-outline" href="mailto:info@veslvault.com">
          <span class="btn-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="2" y="4" width="20" height="16" rx="3" stroke="#1B2B1A" stroke-width="1.6"/>
              <path d="M2 8 L12 14 L22 8" stroke="#1B2B1A" stroke-width="1.6" stroke-linecap="round"/>
            </svg>
          </span>
          info@veslvault.com
        </a>

      </div>
    </div>
  </main>

  <!-- FOOTER -->
  <footer>
    <div class="footer-inner">
      <div class="footer-left">
        <svg width="15" height="16" viewBox="0 0 100 104" fill="none" xmlns="http://www.w3.org/2000/svg">
          <defs><mask id="vmFT"><rect width="100" height="104" fill="black"/><path d="M8,8 L92,8 L50,96 Z" fill="white"/><rect x="8" y="8" width="84" height="9" fill="black"/><rect x="46" y="8" width="8" height="88" fill="black"/></mask></defs>
          <rect width="100" height="104" fill="#8FA08E" mask="url(#vmFT)"/>
        </svg>
        <span class="footer-wordmark">VAULT</span>
      </div>
      <div class="footer-right">
        &copy; 2026 Vault &nbsp;&middot;&nbsp; veslvault.com
      </div>
    </div>
  </footer>

</body>
</html>
